# ─────────────────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
API_BASE_URL=https://YOUR_DOMAIN

# ─────────────────────────────────────────────────────────────────────────────
# Database — FREE options:
#   • Neon       https://neon.tech          (free 0.5 GB, serverless Postgres)
#   • Supabase   https://supabase.com       (free 500 MB)
#   • Railway    https://railway.app        (free $5/mo credit)
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─────────────────────────────────────────────────────────────────────────────
# Redis — FREE options:
#   • Upstash    https://upstash.com        (free 10 000 req/day, TLS)
#   • Redis Cloud https://redis.io/cloud    (free 30 MB)
# ─────────────────────────────────────────────────────────────────────────────
REDIS_URL=rediss://default:password@host:6379

# ─────────────────────────────────────────────────────────────────────────────
# Master HD Wallet
# Generate: node -e "const b=require('bip39');console.log(b.generateMnemonic(256))"
# KEEP THIS SECRET — controls all deposit wallets
# ─────────────────────────────────────────────────────────────────────────────
MASTER_MNEMONIC=twenty four words here ...

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WALLET_ENCRYPTION_KEY=64_hex_chars_here

# ─────────────────────────────────────────────────────────────────────────────
# Admin
# ─────────────────────────────────────────────────────────────────────────────
ADMIN_SECRET=long_random_secret_min_32_chars

# Comma-separated IPs allowed to access /admin routes (leave empty = no restriction)
# Example: ADMIN_WHITELIST_IPS=1.2.3.4,5.6.7.8
ADMIN_WHITELIST_IPS=

# ─────────────────────────────────────────────────────────────────────────────
# EVM Networks — FREE options:
#   • Alchemy    https://alchemy.com        (free 300M compute units/mo)
#   • Infura     https://infura.io          (free 100k req/day)
#   • Ankr       https://rpc.ankr.com       (free public endpoints, no key needed)
#   • Chainlist  https://chainlist.org      (aggregated public RPCs)
# ─────────────────────────────────────────────────────────────────────────────

# Ethereum — use Alchemy or Infura free tier
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
ETH_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# BSC — public Binance endpoints (no key required)
BSC_RPC_URL=https://bsc-dataseed1.binance.org
BSC_WS_URL=wss://bsc-ws-node.nariox.org:443

# ─────────────────────────────────────────────────────────────────────────────
# TRON — FREE options:
#   • TronGrid   https://www.trongrid.io    (free API key, 5000 req/day)
#   • Ankr       https://rpc.ankr.com/tron  (free public)
# Register at trongrid.io → Dashboard → API Keys
# ─────────────────────────────────────────────────────────────────────────────
TRON_FULL_NODE=https://api.trongrid.io
TRON_SOLIDITY_NODE=https://api.trongrid.io
TRON_EVENT_SERVER=https://api.trongrid.io
TRON_API_KEY=your_trongrid_api_key

# ─────────────────────────────────────────────────────────────────────────────
# Solana — FREE options:
#   • Helius     https://helius.dev         (free 100k credits/day, recommended)
#   • Alchemy    https://alchemy.com        (free tier)
#   • Public     https://api.mainnet-beta.solana.com (rate-limited, dev only)
# ─────────────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY
SOLANA_WS_URL=wss://mainnet.helius-rpc.com/?api-key=YOUR_HELIUS_KEY

# ─────────────────────────────────────────────────────────────────────────────
# Master hot wallets — swept funds land here
# These are YOUR wallets; never share their private keys
# ─────────────────────────────────────────────────────────────────────────────
ETH_MASTER_ADDRESS=0x...
BSC_MASTER_ADDRESS=0x...
TRON_MASTER_ADDRESS=T...
SOLANA_MASTER_ADDRESS=...

# ─────────────────────────────────────────────────────────────────────────────
# Telegram Alerts — FREE
# 1. Message @BotFather on Telegram → /newbot
# 2. Get token, start chat with your bot, send a message
# 3. curl "https://api.telegram.org/bot<TOKEN>/getUpdates" → find chat_id
# ─────────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=-100123456789

# ─────────────────────────────────────────────────────────────────────────────
# Business settings
# ─────────────────────────────────────────────────────────────────────────────
DEFAULT_FEE_PERCENT=1.0

ETH_CONFIRMATIONS=12
BSC_CONFIRMATIONS=15
TRON_CONFIRMATIONS=19
SOLANA_CONFIRMATIONS=1

PAYMENT_EXPIRY_SECONDS=3600

WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_DELAY_MS=5000

# Worker health check port (internal only)
WORKER_HEALTH_PORT=3001
